<Window x:Class="Vuokratoimisto_projekti.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Vuokratoimisto_projekti"
        mc:Ignorable="d"
                Title="Kirjaudu sisään" Height="450" Width="800">
    <Grid VerticalAlignment="Center">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock Text="Tervetuloa varausjärjestelmään!" FontSize="24" FontWeight="Bold"
               VerticalAlignment="Top" HorizontalAlignment="Center" Grid.Row="0" Margin="0,-78,0,0"/>
        <!-- Käyttäjätunnus -->
        <TextBox x:Name="txtUsername" Grid.Row="0" Margin="10" Height="30" Width="220"
             VerticalContentAlignment="Center" HorizontalAlignment="Center"
             GotFocus="txtUsername_GotFocus" LostFocus="txtUsername_LostFocus"
             Foreground="Gray" Text="Käyttäjätunnus" KeyDown="txtInput_KeyDown"/>

        <!-- Salasana -->
        <TextBox x:Name="txtVisiblePassword" Grid.Row="1" Margin="10" Height="30" Width="220"
             VerticalContentAlignment="Center" HorizontalAlignment="Center"
             GotFocus="txtVisiblePassword_GotFocus" Visibility="Visible"
             Foreground="Gray" Text="Salasana" KeyDown="txtInput_KeyDown"/>
        <PasswordBox x:Name="txtPassword" Grid.Row="1" Margin="10" Height="30" Width="220"
                 VerticalContentAlignment="Center" HorizontalAlignment="Center"
                 LostFocus="txtPassword_LostFocus" Visibility="Collapsed" KeyDown="txtInput_KeyDown"/>

        <!-- Kirjaudu sisään -painike -->
        <Button Content="Kirjaudu sisään" Grid.Row="2" Margin="10" Height="40" Width="220"
            HorizontalAlignment="Center" VerticalAlignment="Center"
            Foreground="Black" Click="LoginButton_Click"/>
    </Grid>
</Window>
