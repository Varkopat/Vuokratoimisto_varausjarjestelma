<Window x:Class="Vuokratoimisto_projekti.Windows.VarauksetWin1"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Vuokratoimisto_projekti.Windows"
        mc:Ignorable="d"
        Title="VarauksetWin1" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>

        <!--Asiakas tiedot-->
        <GroupBox Header="Nimi" Grid.Row="1">
            <TextBox x:Name="TextBoxNimi" HorizontalAlignment="Left" TextWrapping="Wrap" Width="390" KeyDown="MoveFocusOnEnter"/>
        </GroupBox>
        <GroupBox Header="Puhelin" Grid.Row="1" Grid.Column="1">
            <TextBox x:Name="TextBoxPuhelin" HorizontalAlignment="Left" TextWrapping="Wrap" Width="390" KeyDown="MoveFocusOnEnter"/>
        </GroupBox>
        <GroupBox Header="Kaupunki" Grid.Row="2">
            <TextBox x:Name="TextBoxKaupunki" HorizontalAlignment="Left" TextWrapping="Wrap" Width="390" KeyDown="MoveFocusOnEnter"/>
        </GroupBox>
        <GroupBox Header="Email" Grid.Row="2" Grid.Column="1">
            <TextBox x:Name="TextBoxEmail" HorizontalAlignment="Left" TextWrapping="Wrap" Width="390" KeyDown="MoveFocusOnEnter"/>
        </GroupBox>
        <GroupBox Header="Lähiosoite" Grid.Row="3">
            <TextBox x:Name="TextBoxLahiosoite" HorizontalAlignment="Left" TextWrapping="Wrap" Width="390" KeyDown="MoveFocusOnEnter"/>
        </GroupBox>
        <GroupBox Header="Postinumero" Grid.Row="3" Grid.Column="1">
            <TextBox x:Name="TextBoxPostinumero" HorizontalAlignment="Left" TextWrapping="Wrap" Width="390" PreviewTextInput="TextBoxPostinumero_PreviewTextInput" KeyDown="MoveFocusOnEnter"/>
        </GroupBox>
        <!-- Tekstit -->
        <TextBlock HorizontalAlignment="Center" TextWrapping="Wrap" VerticalAlignment="Center" Width="380" Height="28" FontFamily="Freestyle Script" FontSize="24"><Run Language="fi-fi" Text="Asiakas tiedot"/></TextBlock>
        <TextBlock HorizontalAlignment="Center" TextWrapping="Wrap" VerticalAlignment="Center" Width="380" Height="28" FontFamily="Freestyle Script" FontSize="24" Grid.Row="4"><Run Language="fi-fi" Text="Tee varaus"/></TextBlock>

        <!--Varauksen tekeminen-->
        <GroupBox Header="Paikkakunta" Grid.Row="5">
            <ComboBox x:Name="comPaikkakunta" SelectedIndex="0" Margin="0,0,6,0" Height="24">
                <ComboBoxItem Content="Joensuu"></ComboBoxItem>
                <ComboBoxItem Content="Helsinki"></ComboBoxItem>
                <ComboBoxItem Content="Vantaa"></ComboBoxItem>
                <ComboBoxItem Content="Jyväskylä"></ComboBoxItem>
                <ComboBoxItem Content="Turku"></ComboBoxItem>
                <ComboBoxItem Content="Tampere"></ComboBoxItem>
                <ComboBoxItem Content="Lappeenranta"></ComboBoxItem>
                <ComboBoxItem Content="Espoo"></ComboBoxItem>
            </ComboBox>
        </GroupBox>
        <GroupBox Header="Aloitus pvm" Grid.Row="6">
            <DatePicker x:Name="dpAloituspvm"></DatePicker>
        </GroupBox>
        <GroupBox Header="Lopetus pvm" Grid.Row="6" Grid.Column="1">
            <DatePicker x:Name="dpLopetuspvm"></DatePicker>
        </GroupBox>

        <!--Kalenteri-->

        <!--Painikkeet-->
        <Button x:Name="SeuraavaBtn" Click="SeuraavaBtn_Click" Content="Seuraava" HorizontalAlignment="Center" Grid.Row="8" Grid.Column="1" VerticalAlignment="Center" Height="28" Width="122"/>
        <Button x:Name="TakaisinBtn" Content="Takaisin" Click="TakaisinBtn_Click" HorizontalAlignment="Left" Grid.Row="8" VerticalAlignment="Center" Height="28" Width="122" Margin="106,0,0,0"/>

    </Grid>
</Window>
