<Window x:Class="Vuokratoimisto_projekti.Windows.RaportitWin1"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Vuokratoimisto_projekti.Windows"        
        mc:Ignorable="d"
        Title="Raportit" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition Height="70"/>
        </Grid.RowDefinitions>

        <!-- Otsikkorivi -->
        <StackPanel Orientation="Horizontal" Background="LightGray" Grid.Row="0" Margin="133,75,133,29">
            <TextBlock Text="ID" FontWeight="Bold" Margin="5" Width="25"/>
            <TextBlock Text="Asiakas Nimi" FontWeight="Bold" Margin="5" Width="100"/>
            <TextBlock Text="Varauksen Alku Pvm" FontWeight="Bold" Margin="5" Width="125"/>
            <TextBlock Text="Varauksen Loppu Pvm" FontWeight="Bold" Margin="5" Width="125"/>
            <TextBlock Text="Postitoimipaikka" FontWeight="Bold" Margin="5" Width="100"/>
        </StackPanel>

        <ListBox x:Name="LaskutListBox" SelectionChanged="RaporttiListBox_SelectionChanged"  Margin="133,99,133,29" ItemsSource="{Binding OsittaisetLaskut}">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="{Binding ID}" Margin="5" Width="25"/>
                        <TextBlock Text="{Binding AsiakasNimi}" Margin="5" Width="100"/>
                        <TextBlock Text="{Binding VarauksenAlkuPvm, StringFormat=dd.MM.yyyy}" Margin="5" Width="125"/>
                        <TextBlock Text="{Binding VarauksenLoppuPvm, StringFormat=dd.MM.yyyy}" Margin="5" Width="125"/>
                        <TextBlock Text="{Binding Postitoimipaikka}" Margin="5" Width="100"/>
                    </StackPanel>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
        
        <TextBlock HorizontalAlignment="Center" Margin="0,25,0,0" TextWrapping="Wrap" Text="Raportit" VerticalAlignment="Top" FontFamily="Freestyle Script" FontSize="24" RenderTransformOrigin="0.481,-0.405"/>

        <StackPanel Orientation="Horizontal" Grid.Row="1" HorizontalAlignment="Left" Margin="35,0,0,10" Height="40" VerticalAlignment="Bottom">
            <Button Content="Avaa" x:Name="AvaaBtn" Click="AvaaBtn_Click" Height="28" Width="122"/>
            <Button Content="Takaisin" x:Name="TakaisinBtn" Click="TakaisinBtn_Click" Height="28" Width="122" Margin="10,0,0,0"/>
        </StackPanel>

    </Grid>
</Window>
