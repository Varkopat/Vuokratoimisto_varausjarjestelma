<Window x:Class="Vuokratoimisto_projekti.Windows.VarauksetWin2"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Vuokratoimisto_projekti.Windows"
        mc:Ignorable="d"
        Title="VarauksetWin2" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <!-- Toimipisteen ja huoneen valinta -->
        <GroupBox Header="Toimipiste" Grid.Row="1">
            <ComboBox x:Name="comToimipisteet" HorizontalAlignment="Left" Width="390" RenderTransformOrigin="0.441,0.678" SelectionChanged="comToimipisteet_SelectionChanged"/>
        </GroupBox>
        <GroupBox Header="Huone" Grid.Row="1" Grid.Column="1">
            <ComboBox x:Name="comHuoneet" SelectedIndex="0" HorizontalAlignment="Left" Width="390" RenderTransformOrigin="0.441,0.678" SelectionChanged="comHuoneet_SelectionChanged"/>
        </GroupBox>

        <!-- Huoneen tiedot -->
        <TextBlock HorizontalAlignment="Center" Grid.Row="2" TextWrapping="Wrap" VerticalAlignment="Center" Width="380" Height="28" FontFamily="Freestyle Script" FontSize="24"><Run Language="fi-fi" Text="Huoneen tiedot"/></TextBlock>
        <!-- Tänne tulostuu huoneen tiedot-->
        <TextBox x:Name="infoHuoneet" HorizontalAlignment="Center" Height="96" Grid.RowSpan="2" Grid.Row="3" TextWrapping="Wrap" Text="TextBox" VerticalAlignment="Center" Width="400"/>

        <!--Lisäpalvelut-->
        <TextBlock HorizontalAlignment="Center" Grid.Row="5" TextWrapping="Wrap" VerticalAlignment="Center" Width="380" Height="28" FontFamily="Freestyle Script" FontSize="24"><Run Language="fi-fi" Text="Lisäpalvelut"/></TextBlock>
        <!-- ListBox jonne lisätään lisäpalvelut -->
        <ListBox x:Name="listPalvelut" Grid.Column="1" Grid.Row="5" d:ItemsSource="{d:SampleData ItemCount=5}" Margin="0,48,0,48" Grid.RowSpan="4" SelectionChanged="listPalvelut_SelectionChanged" KeyDown="listPalvelut_KeyDown"/>


        <!--Lisäpalveluiden valinta-->
        <GroupBox Header="Valitse lisäpalvelu ja paina lisää" Grid.Row="6">
            <ComboBox x:Name="comPalvelut" HorizontalAlignment="Left" Width="380" SelectionChanged="comPalvelut_SelectionChanged" KeyDown="comPalvelut_KeyDown"/>
        </GroupBox>


        <!--Painikkeet-->
        <Button x:Name="SeuraavaBtn" Click="SeuraavaBtn_Click" Content="Seuraava" HorizontalAlignment="Center" Grid.Row="8" Grid.Column="1" VerticalAlignment="Center" Height="28" Width="122"/>
        <Button x:Name="TakaisinBtn" Click="TakaisinBtn_Click" Content="Takaisin" HorizontalAlignment="Center" Grid.Row="8" VerticalAlignment="Center" Height="28" Width="122" Margin="0,0,0,0"/>
        <Button x:Name="Lisaa_btn" Click="Lisaa_btn_Click" Content="Lisää" HorizontalAlignment="Left" Margin="10,0,0,0" Grid.Row="7" VerticalAlignment="Center" Height="28" Width="122"/>
        <Button x:Name="Poista_btn" Click="Poista_btn_Click" Content="Poista" HorizontalAlignment="Right" Margin ="0,0,10,0" Grid.Row="7" VerticalAlignment="Center" Height="28" Width="122"/>

        <!--Laskutus tavan valinta-->
        <TextBlock HorizontalAlignment="Center" Grid.Row="2" TextWrapping="Wrap" VerticalAlignment="Center" Width="380" Height="28" FontFamily="Freestyle Script" FontSize="24" Grid.Column="1"><Run Language="fi-fi" Text="Laskutus tapa"/></TextBlock>
        <RadioButton x:Name="radEmail" Grid.Column="1" Content="Email" HorizontalAlignment="Left" Margin="20,0,0,0" Grid.Row="3" VerticalAlignment="Center"/>
        <RadioButton x:Name="radPaperi" Grid.Column="1" Content="Paperi" HorizontalAlignment="Left" Margin="20,0,0,0" Grid.Row="4" VerticalAlignment="Center" Checked="radPaperi_Checked"/>

        <TextBlock HorizontalAlignment="Center" Grid.Row="5" TextWrapping="Wrap" VerticalAlignment="Center" Width="380" Height="28" FontFamily="Freestyle Script" FontSize="24" Grid.Column="1"><Run Language="fi-fi" Text="Valitut palvelut"/></TextBlock>


    </Grid>
</Window>
