<Window x:Class="Vuokratoimisto_projekti.Windows.LaskutiedotWin2"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Vuokratoimisto_projekti.Windows"
        mc:Ignorable="d"
        Title="Laskutiedot" 
        Width="820"
        Height="600">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition Height="70"/>
        </Grid.RowDefinitions>
        <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
        <Grid DataContext="{Binding}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Firman tedot -->
            <StackPanel Orientation="Vertical" Grid.Row="0" Margin="20">
                <TextBlock Text="VuokraToimistot Oy" FontWeight="Bold" FontSize="14"/>
                <TextBlock Text="Karjalankatu 3" FontSize="12"/>
                <TextBlock Text="80200 JOENSUU" FontSize="12"/>
            </StackPanel>

            <!-- Laskun tiedot -->
            <Grid Grid.Row="1" Margin="10,41,10,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="2*"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Margin="0,0,10,0">
                    <TextBlock Text="Asiakkaan tiedot:" FontWeight="Bold" FontSize="12"/>
                    <TextBlock Text="{Binding SelectedLasku.AsiakasNimi}" FontSize="12"/>
                    <TextBlock Text="{Binding SelectedLasku.Lahiosoite}" FontSize="12"/>
                    <TextBlock Text="{Binding SelectedLasku.Postitoimipaikka}" FontSize="12"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Margin="146,0,0,0">
                    <Grid Width="374">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="Lasku:" Grid.Row="0" Grid.Column="0"/>
                        <TextBlock Text="{Binding SelectedLasku.ID}" Grid.Row="0" Grid.Column="1" HorizontalAlignment="Right"/>
                        <TextBlock Text="Päivämäärä" Grid.Row="1" Grid.Column="0"/>
                        <TextBlock Text="{Binding SelectedLasku.VarattuPvm, StringFormat={}{0:dd.MM.yyyy}}" Grid.Row="1" Grid.Column="1" HorizontalAlignment="Right"/>
                        <TextBlock Text="Eräpäivä:" Grid.Row="2" Grid.Column="0"/>
                        <TextBlock Text="{Binding SelectedLasku.DueDate, StringFormat={}{0:dd.MM.yyyy}}" Grid.Row="2" Grid.Column="1" HorizontalAlignment="Right"/>
                        <TextBlock Text="Huomautusaika:" Grid.Row="3" Grid.Column="0"/>
                        <TextBlock Text="8 pv" Grid.Row="3" Grid.Column="1" HorizontalAlignment="Right"/>
                    </Grid>
                </StackPanel>
            </Grid>

            <!-- Varaustiedot -->
            <Grid Grid.Row="2" Margin="10,53,10,10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Text="Varaustiedot" FontWeight="Bold" Background="LightGray" Padding="5" Margin="0,0,0,18"/>
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto" Grid.RowSpan="2">
                        <DataGrid ItemsSource="{Binding SelectedLasku.Palvelut}" AutoGenerateColumns="False" Margin="0,26,0,18" IsReadOnly="True"
                              ScrollViewer.HorizontalScrollBarVisibility="Hidden"
                              ScrollViewer.VerticalScrollBarVisibility="Hidden">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Nimike" Binding="{Binding Nimi}" Width="*" MinWidth="480"/>
                            <DataGridTextColumn Header="Yksikkö" Binding="{Binding Yksikko}" Width="*" MinWidth="100"/>
                            <DataGridTextColumn Header="ALV" Binding="{Binding ALV, StringFormat={}{0:C}}" Width="*" MinWidth="100"/>
                            <DataGridTextColumn Header="Hinta" Binding="{Binding Hinta, StringFormat={}{0:C}}" Width="*" MinWidth="100"/>
                        </DataGrid.Columns>
                </DataGrid>
                    </ScrollViewer>
                    <TextBlock Grid.Row="2" Text="{Binding SelectedLasku.Summa, StringFormat=Lasku yhteensä (EUR) \{0:C\}}" HorizontalAlignment="Right" FontSize="15" Margin="0,10,0,0"/>
            </Grid>
        </Grid>
        </ScrollViewer>
        <Button Content="Sulje" x:Name="SuljeBtn" Click="SuljeBtn_Click" Height="28" Width="122" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,50,10" Grid.Row="1"/>
        <Button Content="Poista" x:Name="PoistaBtn" Click="PoistaBtn_Click" Height="28" Width="122" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="50,0,0,10" Grid.Row="1"/>
        <TextBlock TextWrapping="Wrap" Margin="345,25,125,311" Text="Laskutiedot" TextAlignment="Center" FontFamily="Freestyle Script" FontSize="30"/>
    </Grid>
</Window>
