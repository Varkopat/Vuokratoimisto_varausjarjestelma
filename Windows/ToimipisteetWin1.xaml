<Window x:Class="Vuokratoimisto_projekti.Windows.ToimipisteetWin1"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Vuokratoimisto_projekti.Windows"
        xmlns:cls="clr-namespace:Vuokratoimisto_projekti.Classes"
        mc:Ignorable="d"
        Title="Toimipisteen muokkaus" Height="450" Width="800">
    <Window.DataContext>
        <cls:Toimipiste/>
    </Window.DataContext>
    <StackPanel >

        <!-- Muokattavan Toimipisteen valinta -->
        <GroupBox Header="Valitse toimipiste">
            <StackPanel>
                <ComboBox x:Name="comToimipisteet" DisplayMemberPath="ToimipisteenTiedot" Margin="10" Width="600" HorizontalAlignment="Left"/>
                <StackPanel Orientation="Horizontal" >
                    <Button x:Name="BtnPoista" Content="Poista toimipiste"   Height="30" Width="273" Click="BtnPoista_Click"  />
                    <Button x:Name="BtnMuokkaa"  Content="Muokkaa toimipistettä" Height="30"  Click="BtnMuokkaa_Click" Width="277" Margin="50,0,0,0" />
                </StackPanel>
            </StackPanel>
        </GroupBox>
        
        <!-- Toimipisteen lisäys-->
        <GroupBox Header="Lisää toimipiste">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition />
                    <RowDefinition />
                    <RowDefinition />
                    <RowDefinition />
                    <RowDefinition />
                    <RowDefinition />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>
                <GroupBox Header="Nimi">
                    <TextBox TextWrapping="Wrap" Text="{Binding Nimi}" />
                </GroupBox>
                <GroupBox Grid.Row="1" Header="Kaupunki"  >
                    <TextBox TextWrapping="Wrap" Text="{Binding Postitoimipaikka}" />
                </GroupBox>
                <GroupBox Grid.Row="2" Header="Lähiosoite">
                    <TextBox TextWrapping="Wrap" Text="{Binding Lahiosoite}" />
                </GroupBox>
                <GroupBox Grid.Column="1" Header="Puhelinnumero">
                    <TextBox TextWrapping="Wrap" Text="{Binding Puhelinnro}"/>
                </GroupBox>
                <GroupBox Grid.Column="1" Grid.Row="1" Header="Email">
                    <TextBox TextWrapping="Wrap" Text="{Binding Email}" />
                </GroupBox>
                <GroupBox Grid.Column="1" Grid.Row="2" Header="Postinumero">
                    <TextBox TextWrapping="Wrap" Text="{Binding Postinro}" />
                </GroupBox>
                <Button x:Name="BtnLisaa" Content="Lisää uusi toimipiste" Grid.Row="3"  Grid.Column="1" Margin="125,8,125,10" Click="BtnLisaa_Click" />
            </Grid>
        </GroupBox>
    </StackPanel>
</Window>
