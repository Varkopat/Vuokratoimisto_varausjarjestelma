<Window x:Class="Vuokratoimisto_projekti.Windows.AsHallintWin1"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Vuokratoimisto_projekti.Windows" xmlns:cls="clr-namespace:Vuokratoimisto_projekti.Classes"
        mc:Ignorable="d"
        Title="Asiakkaiden hallinta" Height="450" Width="800">
    <Window.DataContext>
        <cls:Asiakas/>
    </Window.DataContext>


    <StackPanel>
        <GroupBox Header="Hae asiakas">
            <StackPanel>
                <ComboBox x:Name="comAsiakkaat" DisplayMemberPath="Nimi" Margin="10" Width="600" HorizontalAlignment="Left"/>
                <StackPanel Orientation="Horizontal" >
                    <Button x:Name="BtnMuuta"  Content="Muuta asiakasta" Height="30" Width="277" Margin="50,0,0,0" Click="BtnMuuta_Click" />
                    <Button x:Name="BtnPoista" Content="Poista" Width="80" Margin="50,0,0,0" Click="BtnPoista_Click" />
                </StackPanel>
            </StackPanel>
        </GroupBox>

        <!-- Asiakkaiden lisäys-->
        <GroupBox Header="Lisää asiakas">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition />
                    <RowDefinition />
                    <RowDefinition />
                    <RowDefinition />
                    <RowDefinition />
                    <RowDefinition />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition />
                    <ColumnDefinition />
                </Grid.ColumnDefinitions>
                <GroupBox Header="Nimi">
                    <TextBox TextWrapping="Wrap" Text="{Binding Nimi}" />
                </GroupBox>
                <GroupBox Grid.Row="1" Header="Lähiosoite">
                    <TextBox TextWrapping="Wrap" Text="{Binding Lahiosoite}" />
                </GroupBox>
                <GroupBox Grid.Row="2" Header="Postitoimipaikka">
                    <TextBox TextWrapping="Wrap" Text="{Binding Postitoimipaikka}" />
                </GroupBox>
                <GroupBox Grid.Column="1" Header="Postinro">
                    <TextBox TextWrapping="Wrap" Text="{Binding Postinro}"/>
                </GroupBox>
                <GroupBox Grid.Column="1" Grid.Row="1" Header="Email">
                    <TextBox TextWrapping="Wrap" Text="{Binding Email}" />
                </GroupBox>
                <GroupBox Grid.Column="1" Grid.Row="2" Header="Puhelinnro">
                    <TextBox TextWrapping="Wrap" Text="{Binding Puhelinnro}" />
                </GroupBox>
                <Button x:Name="BtnLisaa" Content="Lisää uusi asiakas" Grid.Row="3" Grid.Column="1" Margin="125,10,119,10" Height="30" Click="BtnLisaa_Click" />
            </Grid>
        </GroupBox>
       
        </StackPanel>
</Window>
