<Window x:Class="Vuokratoimisto_projekti.Windows.VarausWin3"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Vuokratoimisto_projekti.Windows"
        mc:Ignorable="d"
        Title="VarausWin3" Height="450" Width="800">
    <Grid>
        
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <TextBlock HorizontalAlignment="Center" TextWrapping="Wrap" VerticalAlignment="Center" Width="380" Height="28" FontFamily="Freestyle Script" FontSize="24" Grid.Row="1"><Run Language="fi-fi" Text="Varauksen tiedot"/></TextBlock>
        <TextBlock x:Name="VarausTiedot" Margin="10,48,0,0" Grid.Row="1" TextWrapping="Wrap" Text="" VerticalAlignment="Top" Grid.ColumnSpan="2" Height="290" Width="780" Grid.RowSpan="8">
            <TextBlock.Inlines>
                <Run Text="Lasku ID:" FontWeight="Bold"/>
                <LineBreak/>
                <Run Text="{Binding ID}" />
                <LineBreak/>
                <Run Text="Asiakas:" FontWeight="Bold" />
                <LineBreak/>
                <Run Text="{Binding AsiakasNimi}" />
                <LineBreak/>
                <Run Text="Osoite:" FontWeight="Bold" />
                <LineBreak/>
                <Run Text="{Binding Lahiosoite}" />
                <LineBreak/>
                <Run Text="{Binding Postitoimipaikka}" />
                <Run Text="{Binding Postinro}"/>
                <LineBreak/>
                <Run Text="Varauksen tiedot:" FontWeight="Bold" />
                <LineBreak/>
                <Run Text="{Binding ToimipisteenNimi}" />
                <LineBreak/>
                <Run Text="Palvelut:" FontWeight="Bold" />
                <LineBreak />
                <Run x:Name="palvelut_tulostus" Text=""/>
                <Run Text="Laskutus:" FontWeight="Bold" />
                <LineBreak/>
                <Run Text="{Binding LaskutusTapa}" />
                <LineBreak/>
                <Run Text="Summa:" FontWeight="Bold" />
                <LineBreak/>
                <Run Text="{Binding Summa, StringFormat={}{0:0.00} €}" />
                <LineBreak/>
                <Run Text="ALV:" FontWeight="Bold" />
                <LineBreak/>
                <Run Text="{Binding ALV, StringFormat={}{0:0.00} €}" />
                <LineBreak/>
            </TextBlock.Inlines>
        </TextBlock>

        <!--Painikkeet-->
        <Button x:Name="ValmisBtn" Click="ValmisBtn_Click" Content="Valmis" HorizontalAlignment="Center" Grid.Row="8" Grid.Column="1" VerticalAlignment="Center" Height="28" Width="122"/>
        <Button x:Name="TakaisinBtn" Click="TakaisinBtn_Click" Content="Takaisin" HorizontalAlignment="Center" Grid.Row="8" VerticalAlignment="Center" Height="28" Width="122"/>




    </Grid>
</Window>
