<Window x:Class="Vuokratoimisto_projekti.Windows.Aloitusikkuna1"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Vuokratoimisto_projekti.Windows"
        mc:Ignorable="d"
        Title="Päävalikko" Height="450" Width="800">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="3*"/>

        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" MinHeight="67" />
            <RowDefinition Height="67*"/>
            <RowDefinition Height="63*"/>
            <RowDefinition Height="Auto" MinHeight="62" />
            <RowDefinition Height="175*"/>
        </Grid.RowDefinitions>

        <!-- Valikkopainikkeet -->
        <Button Content="Varaukset" Grid.Column="0" Margin="10,0,10,0" 
            MouseEnter="Varaukset_MouseEnter" MouseLeave="Intro_MouseLeave" VerticalAlignment="Center" Height="38" Click="Varaukset_Click" RenderTransformOrigin="0.504,-0.461"/>
        <Button Content="Laskut" Grid.Column="0" Grid.Row="1" Margin="10,0,10,0"
            MouseEnter="Laskut_MouseEnter" MouseLeave="Intro_MouseLeave" VerticalAlignment="Center" Height="38" Click="Laskut_Click"/>
        <Button Content="Raportit" Grid.Column="0" Grid.Row="2" Margin="10,0,10,0"
            MouseEnter="Raportit_MouseEnter" MouseLeave="Intro_MouseLeave" VerticalAlignment="Center" Height="38" Click="Raportit_Click"/>
        <Button Content="Asiakashallinta järjestelmä" Grid.Column="0" Grid.Row="3" Margin="10,0,10,0"
    MouseEnter="Asiakashallinta_MouseEnter" MouseLeave="Intro_MouseLeave" VerticalAlignment="Center" Height="38" Click="AsHallint_Click"/>

        <Button Content="Toimipisteiden hallintajärjestelmä" Grid.Column="0" Grid.Row="4" Margin="10,10,10,0"
    MouseEnter="Toimipisteet_MouseEnter" MouseLeave="Intro_MouseLeave" VerticalAlignment="Top" Height="38" Click="Toimipisteet_Click" />

        <Button Content="Palveluiden hallintajärjestelmä" Grid.Column="0" Grid.Row="4" Margin="10,0,10,0"
            MouseEnter="PalveluidenHallinta_MouseEnter" MouseLeave="PalveluidenHallinta_MouseLeave" VerticalAlignment="Center" Height="38" Click="PalveluidenHallinta_Click" />
       


        <!-- Info-alue -->
        <TextBlock x:Name="infoTextBlock" Text="Liikuta hiiri painikkeiden päälle nähdäksesi lisätietoja." Grid.Column="1" Grid.Row="2"
               VerticalAlignment="Center" HorizontalAlignment="Center"
               FontSize="16" TextWrapping="Wrap" Height="54" Width="386"
               Background="LightBlue" Opacity="0.8" TextAlignment="Center"
               FontFamily="Segoe UI" FontWeight="SemiBold"/>

        <!-- Sulje-painike -->
        <Button Content="Sulje" Grid.Column="1" Grid.Row="4" Margin="0,0,10,18" Width="40" 
            HorizontalAlignment="Right" VerticalAlignment="Bottom" Click="CloseButton_Click" Height="18" RenderTransformOrigin="0.354,4.466"/>
        

    </Grid>
</Window>
